<script>
/* ════════════════════════════════════════
   ⚙️ CONFIG — EDIT ONLY THIS SECTION
════════════════════════════════════════ */
const CONFIG = {
  password:   "2602",         // ← the secret word
  sisterName: "SEHRISH",          // ← her name
  yourName:   "Sanif",    // ← your name (for signature)

  letterBody: [
    "My Dearest SEHRISH,",
    "Happy Birthday to the most precious soul. 🤍 On your special day, I pray that Allah fills your life with endless happiness, peace, success, and beautiful moments.",
    "Thank you for being such an amazing sister. Your kindness, care, and support mean more to me than words can ever express.",
    "May Allah bless you with a long, beautiful life and make all your dreams come true."
  ],

  finalLine: "🎂 Happy Birthday, SEHRISH! May Allah bless you with a long, beautiful, and joyful life. Always keep smiling. 🤍🌸",

  wrongMsgs: [
    "Hmm, not quite! The garden isn't open yet 🌱",
    "Almost — think of something springy! 🌸",
    "Oops, try again my love 🌷",
    "The flowers are still waiting… 🌼",
  ],
};

/* ════════════════════════════════════════
   🔒 PASSWORD
════════════════════════════════════════ */
let attempts = 0;
document.getElementById('pw-field').addEventListener('keydown', e => { if(e.key==='Enter') tryUnlock(); });

function tryUnlock() {
  const val = document.getElementById('pw-field').value.trim();
  const msg = document.getElementById('lock-msg');
  if (val.toLowerCase() === CONFIG.password.toLowerCase()) {
    msg.textContent = '✿ Opening your garden…';
    msg.style.color = 'var(--moss)';
    setTimeout(unlock, 700);
  } else {
    attempts++;
    msg.textContent = CONFIG.wrongMsgs[(attempts-1) % CONFIG.wrongMsgs.length];
    const card = document.getElementById('lock-card');
    card.classList.remove('wiggle'); void card.offsetWidth; card.classList.add('wiggle');
  }
}

function unlock() {
  document.getElementById('lock-screen').classList.add('exit');
  setTimeout(() => {
    document.getElementById('lock-screen').style.display = 'none';
    document.getElementById('site').classList.add('show');
    document.getElementById('music-pill').classList.add('show');
    populate();
    buildGarden();
    startBlossoms();
    document.addEventListener('click', tryAutoPlay, { once:true });
  }, 800);
}

/* ════════════════════════════════════════
   📝 POPULATE
════════════════════════════════════════ */
function populate() {
  document.getElementById('hero-name').textContent = CONFIG.sisterName;
  const ds = new Date().toLocaleDateString('en-US',{weekday:'long',year:'numeric',month:'long',day:'numeric'});
  document.getElementById('hero-date').textContent = ds;
  document.getElementById('letter-date').textContent = ds;
  document.getElementById('letter-salutation').textContent = `My dearest ${CONFIG.sisterName},`;
  document.getElementById('final-highlight').textContent = CONFIG.finalLine;
  document.getElementById('letter-sign').textContent = `With all my love,\n${CONFIG.yourName} 🌸`;
}

/* ════════════════════════════════════════
   📜 LETTER TYPING
════════════════════════════════════════ */
function openLetter() {
  document.getElementById('letter-gate').style.display = 'none';
  const body = document.getElementById('letter-body');
  body.classList.add('open');
  typeLetter();
}

function typeLetter() {
  const el = document.getElementById('letter-text');
  const cur = document.createElement('span'); cur.className = 'typing-cursor';
  let pi=0, ci=0, curP=null;
  function next() {
    if (pi >= CONFIG.letterBody.length) {
      cur.remove();
      document.getElementById('final-highlight').style.display = 'block';
      document.getElementById('letter-sign').style.display = 'block';
      setTimeout(() => document.getElementById('final-highlight').scrollIntoView({behavior:'smooth',block:'center'}), 400);
      return;
    }
    if (ci===0) { curP=document.createElement('p'); el.appendChild(curP); el.appendChild(cur); }
    curP.textContent = CONFIG.letterBody[pi].slice(0, ci+1);
    ci++;
    if (ci >= CONFIG.letterBody[pi].length) { pi++; ci=0; setTimeout(next,480); }
    else { setTimeout(next, 26+Math.random()*18); }
  }
  next();
}

/* ════════════════════════════════════════
   🌷 GARDEN
════════════════════════════════════════ */
const FD = [
  {left:50,h:200,ps:40,col:'#f2a7bb',n:8,bd:0,   dur:'4.5s',sl:'3deg'},
  {left:22,h:165,ps:32,col:'#a8c5a0',n:6,bd:.3,  dur:'5.2s',sl:'-4deg'},
  {left:76,h:178,ps:34,col:'#fddcb5',n:7,bd:.5,  dur:'4.8s',sl:'4deg'},
  {left:36,h:132,ps:26,col:'#ce93d8',n:6,bd:.7,  dur:'5.5s',sl:'-3deg'},
  {left:63,h:148,ps:28,col:'#ef9a9a',n:5,bd:.9,  dur:'4.2s',sl:'5deg'},
  {left:12,h:115,ps:22,col:'#80cbc4',n:5,bd:1.1, dur:'6s',  sl:'-4deg'},
  {left:88,h:122,ps:24,col:'#fff176',n:6,bd:1.3, dur:'4s',  sl:'3deg'},
  {left:30,h: 95,ps:20,col:'#f48fb1',n:5,bd:1.5, dur:'5.8s',sl:'-5deg'},
];

function buildGarden() {
  const stage = document.getElementById('garden-stage');
  const ground = stage.querySelector('.garden-ground');

  FD.forEach((f,i) => {
    const wrap = document.createElement('div'); wrap.className='g-flower';
    wrap.style.left=f.left+'%';
    wrap.style.setProperty('--dur',f.dur);
    wrap.style.setProperty('--sdel',(i*.25)+'s');
    wrap.style.setProperty('--sl',f.sl);

    const head=document.createElement('div'); head.className='g-head';
    head.style.width=(f.ps*2.6)+'px'; head.style.height=(f.ps*2.6)+'px';

    for(let p=0;p<f.n;p++){
      const angle=(360/f.n)*p;
      const petal=document.createElement('div'); petal.className='g-petal';
      petal.style.setProperty('--angle',angle+'deg');
      petal.style.setProperty('--bloom-dur','1.1s');
      petal.style.setProperty('--bloom-del',(f.bd+p*.05)+'s');
      petal.style.width=f.ps+'px'; petal.style.height=f.ps+'px';
      petal.style.background=f.col; petal.style.transform=`rotate(${angle}deg)`;
      head.appendChild(petal);
    }
    const center=document.createElement('div'); center.className='g-center';
    head.appendChild(center);

    const stem=document.createElement('div'); stem.className='g-stem';
    stem.style.height=f.h+'px'; stem.style.position='relative';
    const leaf=document.createElement('div'); leaf.className='g-leaf';
    leaf.style.top=Math.floor(f.h*.45)+'px';
    leaf.style[i%2===0?'left':'right']='4px';
    leaf.style.transform=i%2===0?'rotate(-40deg)':'rotate(140deg) scaleX(-1)';
    stem.appendChild(leaf);

    wrap.appendChild(head); wrap.appendChild(stem);
    stage.insertBefore(wrap, ground);
  });

  ['🦋','🦋','🌻'].forEach((e,i) => {
    const b=document.createElement('div'); b.className='butterfly';
    b.textContent=e; b.style.left=(15+i*30)+'%'; b.style.top=(20+i*10)+'%';
    b.style.setProperty('--flt-dur',(7+i*2)+'s'); b.style.animationDelay=(i*2)+'s';
    stage.appendChild(b);
  });

  // Drifting petals
  const styleEl=document.createElement('style');
  styleEl.textContent=`@keyframes fall{0%{transform:translateY(-5vh) rotate(0deg);opacity:.7}100%{transform:translateY(108vh) rotate(540deg);opacity:0}}`;
  document.head.appendChild(styleEl);
  ['🌸','🌺','🌷','🌼','✿'].forEach(p => {
    for(let j=0;j<3;j++){
      const el=document.createElement('div');
      el.style.cssText=`position:fixed;font-size:${.8+Math.random()*.7}rem;left:${Math.random()*100}vw;top:-5vh;animation:fall ${9+Math.random()*10}s linear ${Math.random()*12}s infinite;pointer-events:none;z-index:1;opacity:.55;`;
      el.textContent=p; document.body.appendChild(el);
    }
  });
}

/* ════════════════════════════════════════
   💫 CANVAS BLOSSOMS
════════════════════════════════════════ */
function startBlossoms() {
  const cv=document.getElementById('blossom-canvas'), ctx=cv.getContext('2d');
  const resize=()=>{cv.width=innerWidth;cv.height=innerHeight};
  resize(); window.addEventListener('resize',resize);
  const G=['♥','✦','✿','⁕','✧','·','❀'];
  const C=['#f2a7bb','#a8c5a0','#fddcb5','#fcd5e0','#d4e8d0','#f5c842'];
  function mk(atTop){return{x:Math.random()*innerWidth,y:atTop?-20:Math.random()*innerHeight,vx:(Math.random()-.5)*.4,vy:.2+Math.random()*.5,alpha:0,maxA:.2+Math.random()*.3,size:10+Math.random()*12,g:G[Math.floor(Math.random()*G.length)],c:C[Math.floor(Math.random()*C.length)],rot:Math.random()*360,rotV:(Math.random()-.5)*2}}
  const ps=Array.from({length:50},()=>mk());
  (function loop(){
    ctx.clearRect(0,0,cv.width,cv.height);
    ps.forEach((p,i)=>{
      p.x+=p.vx;p.y+=p.vy;p.rot+=p.rotV;p.alpha=Math.min(p.alpha+.008,p.maxA);
      if(p.y>cv.height+20){ps[i]=mk(true);return}
      ctx.save();ctx.globalAlpha=p.alpha;ctx.fillStyle=p.c;ctx.font=`${p.size}px serif`;
      ctx.translate(p.x,p.y);ctx.rotate(p.rot*Math.PI/180);ctx.fillText(p.g,0,0);ctx.restore();
    });
    requestAnimationFrame(loop);
  })();
}

/* ════════════════════════════════════════
   🎵 MUSIC
════════════════════════════════════════ */
let audioCtx,playing=false,nodes=[];
function tryAutoPlay(){if(!playing)toggleMusic()}
function toggleMusic(){
  const btn=document.getElementById('music-btn');
  const aud=document.getElementById('bg-audio');
  if(aud.querySelector('source')){
    if(playing){aud.pause();btn.textContent='🎵';btn.classList.remove('playing')}
    else{aud.play().catch(()=>{});btn.textContent='🔇';btn.classList.add('playing')}
    playing=!playing;return;
  }
  if(playing){
    nodes.forEach(n=>{try{n.stop()}catch(e){}});nodes=[];audioCtx?.suspend();
    btn.textContent='🎵';btn.classList.remove('playing');playing=false;
  } else {
    if(!audioCtx)audioCtx=new(window.AudioContext||window.webkitAudioContext)();
    audioCtx.resume();playSpring();btn.textContent='🔇';btn.classList.add('playing');playing=true;
  }
}
function playSpring(){
  const f=[261.63,293.66,329.63,392,440,523.25];
  function note(freq,t,dur,vol=.045){
    const o=audioCtx.createOscillator(),g=audioCtx.createGain();
    o.connect(g);g.connect(audioCtx.destination);o.type='sine';
    o.frequency.setValueAtTime(freq,t);g.gain.setValueAtTime(0,t);
    g.gain.linearRampToValueAtTime(vol,t+.2);g.gain.linearRampToValueAtTime(0,t+dur);
    o.start(t);o.stop(t+dur+.1);nodes.push(o);
  }
  function phrase(t){
    if(!playing)return;
    [0,2,4,5,4,2,1,3,5,4].forEach((idx,i)=>note(f[idx%f.length],t+i*.8,1.2));
    note(130.81,t,8,.025);
    setTimeout(()=>phrase(audioCtx.currentTime),8200);
  }
  phrase(audioCtx.currentTime+.1);
}

/* ════════════════════════════════════════
   🔗 SHARE
════════════════════════════════════════ */
function doShare(){
  if(navigator.share){navigator.share({title:`Happy Birthday ${CONFIG.sisterName}! 🌸`,url:location.href}).catch(()=>{})}
  else doCopy();
}
function doCopy(){
  navigator.clipboard.writeText(location.href).then(()=>{
    const t=document.getElementById('share-toast');t.classList.add('show');
    setTimeout(()=>t.classList.remove('show'),3000);
  }).catch(()=>alert(location.href));
}
</script>
